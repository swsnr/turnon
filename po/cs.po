msgstr "_Název hostitele nebo IP adresa"

#: resources/ui/edit-device-dialog.blp:54
msgctxt "edit-device-dialog.entry.host.tooltip"
msgid ""
"The hostname or IP address of the device to check whether it has woken up"
msgstr ""
"Název hostitele nebo IP adresa zařízení pro kontrolu, zda je zařízení "
"probuzené"

#: resources/ui/edit-device-dialog.blp:69
msgctxt "edit-device-dialog.entry.host.feedback"
msgid "Please specify a target host to check availability"
msgstr "Zadejte cílového hostitele jehož dostupnost chcete zkontrolovat"

#: resources/ui/edit-device-dialog.blp:82
msgctxt "edit-device-dialog.entry.socket-address.feedback"
msgid ""
"This looks like a socket address with host and port, but a port is not "
"permitted here!"
msgstr ""
"Toto vypadá jako adresa soketu (hostitel:port) – do této kolonky ale patří "
"jen hostitel (dvojtečku a číslo portu odmažte)!"

#: resources/ui/edit-device-dialog.blp:95
msgctxt "edit-device-dialog.entry.host.feedback"
msgid "This looks like a generic name resolved via DNS."
msgstr "Toto vypadá jako generický název zjištěný prostřednictvím DNS."

#: resources/ui/edit-device-dialog.blp:109
msgctxt "edit-device-dialog.entry.host.feedback"
msgid "This is a valid IPv4 address."
msgstr "Toto je platná adresa IPv4."

#: resources/ui/edit-device-dialog.blp:123
msgctxt "edit-device-dialog.entry.host.feedback"
msgid "This is a valid IPv6 address."
msgstr "Toto je platná adresa IPv6."

#: resources/ui/edit-device-dialog.blp:135
msgctxt "edit-device-dialog.group.title"
msgid "Magic packet destination"
msgstr "Cíl magického paketu"

#: resources/ui/edit-device-dialog.blp:136
