msgstr "_Cílová adresa"

#: resources/ui/edit-device-dialog.blp:140
msgctxt "edit-device-dialog.entry.target-address.tooltip"
msgid ""
"The target address as IPv4 or IPv6 socket address, i.e. IP address and port"
msgstr "Cílová adresa jako ta IPv4 nebo IPv6 soketu – tj. IP adresa a port"

#: resources/ui/edit-device-dialog.blp:155
msgctxt "edit-device-dialog.entry.target_address.feedback"
msgid "Please provide a valid target socket address for the device."
msgstr "Zadejte platnou adresu soketu pro toto zařízení."

#: resources/ui/edit-device-dialog.blp:169
msgctxt "edit-device-dialog.entry.target_address.feedback"
msgid "This is a valid IPv4 socket address."
msgstr "Toto je platná IPv4 adresa soketu."

#: resources/ui/edit-device-dialog.blp:183
msgctxt "edit-device-dialog.entry.target_address.feedback"
msgid "This is a valid IPv6 socket address."
msgstr "Toto je platná IPv6 adresa soketu."

