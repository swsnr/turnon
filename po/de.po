msgid "Magic packet destination"
msgstr "Ziel des magischen Pakets"

#: resources/edit-device-dialog.blp:150
msgctxt "edit-device-dialog.group.description"
msgid "The destination address the magic packet for this device is sent to."
msgstr ""
"Die Zieladresse, an die das magische Paket für dieses Gerät geschickt wird."

#: resources/edit-device-dialog.blp:154
msgctxt "edit-device-dialog.entry.target-address.title"
msgid "_Target address"
msgstr "_Zieladresse"

#: resources/edit-device-dialog.blp:157
msgctxt "edit-device-dialog.entry.target-address.tooltip"
msgid ""
"The target address as IPv4 or IPv6 socket address, i.e. IP address and port"
msgstr ""
"Die Zieladresse als IPv4 oder IPv6 Socketadresse, i.e. IP-Adresse und Port"

#: resources/edit-device-dialog.blp:175
msgctxt "edit-device-dialog.entry.target_address.feedback"
msgid "Please provide a valid target socket address for the device."
msgstr "Bitte ein gültige Socketadresse als Ziel für dieses Gerät angeben."

#: resources/edit-device-dialog.blp:192
msgctxt "edit-device-dialog.entry.target_address.feedback"
msgid "This is a valid IPv4 socket address."
msgstr "Eine gültige IPv4-Socketadresse."

#: resources/edit-device-dialog.blp:209
msgctxt "edit-device-dialog.entry.target_address.feedback"
msgid "This is a valid IPv6 socket address."
msgstr "Eine gültige IPv6-Socketadresse."

