msgid "_Host name or IP address"
msgstr "_Hostname oder IP-Adresse"

#: resources/edit-device-dialog.blp:56
msgctxt "edit-device-dialog.entry.host.tooltip"
msgid ""
"The hostname or IP address of the device to check whether it has woken up"
msgstr ""
"Der Host-Name oder die IP-Adresse des Geräts zur Überprüfung des Status"

#: resources/edit-device-dialog.blp:74
msgctxt "edit-device-dialog.entry.host.feedback"
msgid "Please specify a target host to check availability"
msgstr "Bitte den Ziel-Host zur Verfügbarkeitsprüfung angeben"

#: resources/edit-device-dialog.blp:90
msgctxt "edit-device-dialog.entry.socket-address.feedback"
msgid ""
"This looks like a socket address with host and port, but a port is not "
"permitted here!"
msgstr ""
"Eine Socketadresse mit Hostnamen und Port, aber die Angabe eines Ports ist "
"hier nicht erlaubt!"

#: resources/edit-device-dialog.blp:106
msgctxt "edit-device-dialog.entry.host.feedback"
msgid "This looks like a generic name resolved via DNS."
msgstr "Ein generischer Name zur Auflösung mittels DNS."

