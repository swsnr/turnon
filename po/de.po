msgstr "Die Hardware-Adresse dieses Geräts"

#: resources/edit-device-dialog.blp:48
msgctxt "edit-device-dialog.entry.mac_address.feedback"
msgid "This is no valid 48-bit MAC address."
msgstr "Eine gültige 48-Bit MAC-Adresse."

#: resources/edit-device-dialog.blp:53
